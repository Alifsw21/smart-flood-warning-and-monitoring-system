    {
      "name": "IoT (Node-RED ingress)",
      "description": "Uses client_credentials auto-auth (same flow as Node-RED S1). Collection pre-request is skipped for /iot/*; this folder fetches its own token.",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const tokenStillValid = () => {",
              "    const token = pm.collectionVariables.get('iotAccessToken');",
              "    const expiresAt = Number(pm.collectionVariables.get('iotAccessTokenExpiresAt') || '0');",
              "    const skewMs = 60 * 1000;",
              "    return Boolean(token) && expiresAt > 0 && Date.now() < expiresAt - skewMs;",
              "};",
              "",
              "const ensureClientCredentialsToken = async () => {",
              "    if (tokenStillValid()) {",
              "        return;",
              "    }",
              "",
              "    const baseUrl = pm.collectionVariables.get('baseUrl');",
              "    const response = await pm.sendRequest({",
              "        url: `${baseUrl}/oauth/token`,",
              "        method: 'POST',",
              "        header: { 'Content-Type': 'application/json' },",
              "        body: {",
              "            mode: 'raw',",
              "            raw: JSON.stringify({",
              "                grant_type: 'client_credentials',",
              "                client_id: pm.collectionVariables.get('gatewayClientId'),",
              "                client_secret: pm.collectionVariables.get('gatewayClientSecret'),",
              "            }),",
              "        },",
              "    });",
              "",
              "    if (response.code !== 200) {",
              "        throw new Error(`IoT auto OAuth failed (${response.code}): ${response.text()}`);",
              "    }",
              "",
              "    const json = response.json();",
              "    pm.collectionVariables.set('iotAccessToken', json.access_token);",
              "    const ttl = Number(json.expires_in || 3600);",
              "    pm.collectionVariables.set('iotAccessTokenExpiresAt', String(Date.now() + ttl * 1000));",
              "};",
              "",
              "await ensureClientCredentialsToken();"
            ]
          }
        }
      ],
      "item": [
        {
          "name": "POST /iot/traffic",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{iotAccessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/iot/traffic",
            "body": {
              "mode": "raw",
              "raw": "{\"idNode\":1,\"tinggiAir\":12,\"kelembapanTanah\":55,\"curahHujan\":6,\"suhuRataRata\":29,\"kelembapanUdara\":72,\"kecepatanAngin\":8}"
            }
          }
        },

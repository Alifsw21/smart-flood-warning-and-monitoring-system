<?php

require_once __DIR__ . '/../models/FloodHistory.php';

class FloodHistoryController
{
    private $model;

    public function __construct($db)
    {
        $this->model = new FloodHistory($db);
    }

    public function index()
    {
        echo json_encode(
            $this->model->getAll()
        );
    }

    public function show($id)
    {
        echo json_encode(
            $this->model->getById($id)
        );
    }

    public function destroy($id)
    {
        $this->model->delete($id);

        echo json_encode([
            "message" => "Riwayat banjir berhasil dihapus"
        ]);
    }
}

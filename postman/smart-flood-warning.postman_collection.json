    { "key": "accessTokenExpiresAt", "value": "0" },
    { "key": "accessTokenGrantType", "value": "" },
    { "key": "citizenClientId", "value": "citizen-app" },
    { "key": "citizenClientSecret", "value": "CitizenSecretDev123" },
    { "key": "gatewayClientId", "value": "gateway" },
    { "key": "gatewayClientSecret", "value": "GatewaySecretDev123" },
    { "key": "devUsername", "value": "hadiputra2" },

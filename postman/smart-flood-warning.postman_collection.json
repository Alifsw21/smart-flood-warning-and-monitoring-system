        {
          "name": "Reset all tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "['accessToken','refreshToken','accessTokenExpiresAt','accessTokenGrantType','adminAccessToken','adminRefreshToken','adminAccessTokenExpiresAt','adminAccessTokenGrantType','iotAccessToken','iotAccessTokenExpiresAt'].forEach((key) => {",
                  "    if (key.endsWith('ExpiresAt')) {",
                  "        pm.collectionVariables.set(key, '0');",
                  "    } else {",
                  "        pm.collectionVariables.unset(key);",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "Gateway Health",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" }
        },
        {
          "name": "GET /metrics",
          "request": { "method": "GET", "url": "{{baseUrl}}/metrics" }
        }
      ]

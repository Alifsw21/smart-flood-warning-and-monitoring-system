{
  "info": {
    "name": "Smart Flood Warning API",
    "description": "Postman collection for smart-flood-warning-and-monitoring-system (Spec §12).\n\nUsage:\n1. Set collection variables if needed (defaults target local docker compose via SSH tunnel: baseUrl=http://localhost:3530).\n2. Citizen requests auto-fetch {{accessToken}} (hadiputra2 / kelompok2dev).\n3. Admin-only requests auto-fetch {{adminAccessToken}} (dinasari1 / kelompok2dev).\n4. IoT folder auto-fetches client_credentials token (Node-RED S1 flow).\n5. Manual Auth requests remain available for debugging.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const saveTokenResponse = (json, prefix = '') => {",
          "    const accessKey = prefix ? `${prefix}AccessToken` : 'accessToken';",
          "    const refreshKey = prefix ? `${prefix}RefreshToken` : 'refreshToken';",
          "    const expiresKey = prefix ? `${prefix}AccessTokenExpiresAt` : 'accessTokenExpiresAt';",
          "    const grantKey = prefix ? `${prefix}AccessTokenGrantType` : 'accessTokenGrantType';",
          "    if (json.access_token) {",
          "        pm.collectionVariables.set(accessKey, json.access_token);",
          "    }",
          "    if (json.refresh_token) {",
          "        pm.collectionVariables.set(refreshKey, json.refresh_token);",
          "    }",
          "    pm.collectionVariables.set(grantKey, 'password');",
          "    const ttl = Number(json.expires_in || 3600);",
          "    pm.collectionVariables.set(expiresKey, String(Date.now() + ttl * 1000));",
          "};",
          "",
          "const clearTokenVars = (prefix = '') => {",
          "    const accessKey = prefix ? `${prefix}AccessToken` : 'accessToken';",
          "    const refreshKey = prefix ? `${prefix}RefreshToken` : 'refreshToken';",
          "    const expiresKey = prefix ? `${prefix}AccessTokenExpiresAt` : 'accessTokenExpiresAt';",
          "    const grantKey = prefix ? `${prefix}AccessTokenGrantType` : 'accessTokenGrantType';",
          "    pm.collectionVariables.unset(accessKey);",
          "    pm.collectionVariables.unset(refreshKey);",
          "    pm.collectionVariables.set(expiresKey, '0');",
          "    pm.collectionVariables.unset(grantKey);",
          "};",
          "",
          "const ADMIN_REQUESTS = new Set([",
          "    'GET /api/citizens (admin)',",
          "    'PATCH /api/reports/:id/status (admin)',",
          "]);",
          "",
          "const isAdminRequest = () => ADMIN_REQUESTS.has(pm.info.requestName || '');",
          "",
          "const getAuthConfig = () => {",
          "    if (isAdminRequest()) {",
          "        return {",
          "            prefix: 'admin',",
          "            username: pm.collectionVariables.get('adminUsername'),",
          "            password: pm.collectionVariables.get('adminPassword'),",
          "            expectedGrant: 'password',",
          "        };",
          "    }",
          "    return {",
          "        prefix: '',",
          "        username: pm.collectionVariables.get('devUsername'),",
          "        password: pm.collectionVariables.get('devPassword'),",
          "        expectedGrant: 'password',",
          "    };",
          "};",
          "",
          "const shouldSkipAutoAuth = () => {",
          "    const path = pm.request.url.getPath();",
          "    const name = pm.info.requestName || '';",
          "    if (path === '/health' || path === '/metrics') return true;",
          "    if (path === '/oauth/token' || path === '/oauth/introspect' || path === '/oauth/revoke') return true;",
          "    if (path.startsWith('/api/auth/login')) return true;",
          "    if (path.startsWith('/iot/')) return true;",
          "    if (name.startsWith('OAuth Token') || name === 'POST /api/auth/login') return true;",
          "    if (name === 'Gateway Health' || name === 'GET /metrics' || name === 'Reset all tokens') return true;",
          "    return false;",
          "};",
          "",
          "const introspectToken = async (token) => {",
          "    if (!token) return false;",
          "    const baseUrl = pm.collectionVariables.get('baseUrl');",
          "    const response = await pm.sendRequest({",
          "        url: `${baseUrl}/oauth/introspect`,",
          "        method: 'POST',",
          "        header: { 'Content-Type': 'application/json' },",
          "        body: {",
          "            mode: 'raw',",
          "            raw: JSON.stringify({",
          "                token,",
          "                client_id: pm.collectionVariables.get('gatewayClientId'),",
          "                client_secret: pm.collectionVariables.get('gatewayClientSecret'),",
          "            }),",
          "        },",
          "    });",
          "    if (response.code !== 200) return false;",
          "    return response.json().active === true;",
          "};",
          "",
          "const tokenStillValid = async (prefix = '', expectedGrant = 'password') => {",
          "    const accessKey = prefix ? `${prefix}AccessToken` : 'accessToken';",
          "    const expiresKey = prefix ? `${prefix}AccessTokenExpiresAt` : 'accessTokenExpiresAt';",
          "    const grantKey = prefix ? `${prefix}AccessTokenGrantType` : 'accessTokenGrantType';",
          "    const token = pm.collectionVariables.get(accessKey);",
          "    const expiresAt = Number(pm.collectionVariables.get(expiresKey) || '0');",
          "    const grantType = pm.collectionVariables.get(grantKey) || '';",
          "    const skewMs = 60 * 1000;",
          "    if (!token || expiresAt <= 0 || Date.now() >= expiresAt - skewMs) return false;",
          "    if (grantType && grantType !== expectedGrant) return false;",
          "    return introspectToken(token);",
          "};",
          "",
          "const ensurePasswordGrantToken = async () => {",
          "    if (shouldSkipAutoAuth()) {",
          "        return;",
          "    }",
          "",
          "    const { prefix, username, password, expectedGrant } = getAuthConfig();",
          "    if (await tokenStillValid(prefix, expectedGrant)) {",
          "        return;",
          "    }",
          "",
          "    const baseUrl = pm.collectionVariables.get('baseUrl');",
          "    const refreshKey = prefix ? `${prefix}RefreshToken` : 'refreshToken';",
          "    const refreshToken = pm.collectionVariables.get(refreshKey);",
          "    let response;",
          "",
          "    if (refreshToken) {",
          "        response = await pm.sendRequest({",
          "            url: `${baseUrl}/oauth/token`,",
          "            method: 'POST',",
          "            header: { 'Content-Type': 'application/json' },",
          "            body: {",
          "                mode: 'raw',",
          "                raw: JSON.stringify({",
          "                    grant_type: 'refresh_token',",
          "                    client_id: pm.collectionVariables.get('citizenClientId'),",
          "                    client_secret: pm.collectionVariables.get('citizenClientSecret'),",
          "                    refresh_token: refreshToken,",
          "                }),",
          "            },",
          "        });",
          "    }",
          "",
          "    if (!response || response.code !== 200) {",
          "        response = await pm.sendRequest({",
          "            url: `${baseUrl}/oauth/token`,",
          "            method: 'POST',",
          "            header: { 'Content-Type': 'application/x-www-form-urlencoded' },",
          "            body: {",
          "                mode: 'urlencoded',",
          "                urlencoded: [",
          "                    { key: 'grant_type', value: 'password' },",
          "                    { key: 'username', value: username },",
          "                    { key: 'password', value: password },",
          "                    { key: 'client_id', value: pm.collectionVariables.get('citizenClientId') },",
          "                    { key: 'client_secret', value: pm.collectionVariables.get('citizenClientSecret') },",
          "                ],",
          "            },",
          "        });",
          "    }",
          "",
          "    if (response.code !== 200) {",
          "        const who = prefix === 'admin' ? 'admin (dinasari1)' : 'citizen (hadiputra2)';",
          "        throw new Error(`Auto OAuth failed for ${who} (${response.code}): ${response.text()}`);",
          "    }",
          "",
          "    saveTokenResponse(response.json(), prefix);",
          "};",
          "",
          "await ensurePasswordGrantToken();"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (pm.response.code !== 403) return;",
          "let body = {};",
          "try { body = pm.response.json(); } catch { return; }",
          "if (body.message !== 'Token tidak valid') return;",
          "const name = pm.info.requestName || '';",
          "if (name.includes('(admin)')) {",
          "    pm.collectionVariables.unset('adminAccessToken');",
          "    pm.collectionVariables.unset('adminRefreshToken');",
          "    pm.collectionVariables.set('adminAccessTokenExpiresAt', '0');",
          "    pm.collectionVariables.unset('adminAccessTokenGrantType');",
          "} else {",
          "    pm.collectionVariables.unset('accessToken');",
          "    pm.collectionVariables.unset('refreshToken');",
          "    pm.collectionVariables.set('accessTokenExpiresAt', '0');",
          "    pm.collectionVariables.unset('accessTokenGrantType');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3530" },
    { "key": "oauthUrl", "value": "http://localhost:3531" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "accessTokenExpiresAt", "value": "0" },
    { "key": "accessTokenGrantType", "value": "" },
    { "key": "citizenClientId", "value": "citizen-app" },
    { "key": "citizenClientSecret", "value": "CitizenSecretDev123" },
    { "key": "gatewayClientId", "value": "gateway" },
    { "key": "gatewayClientSecret", "value": "GatewaySecretDev123" },
    { "key": "devUsername", "value": "hadiputra2" },
    { "key": "devPassword", "value": "kelompok2dev" },
    { "key": "adminUsername", "value": "dinasari1" },
    { "key": "adminPassword", "value": "kelompok2dev" },
    { "key": "adminAccessToken", "value": "" },
    { "key": "adminRefreshToken", "value": "" },
    { "key": "adminAccessTokenExpiresAt", "value": "0" },
    { "key": "adminAccessTokenGrantType", "value": "" },
    { "key": "iotAccessToken", "value": "" },
    { "key": "iotAccessTokenExpiresAt", "value": "0" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "OAuth Token (password grant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.access_token) {",
                  "        pm.collectionVariables.set('accessToken', json.access_token);",
                  "    }",
                  "    if (json.refresh_token) {",
                  "        pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "    }",
                  "    const ttl = Number(json.expires_in || 3600);",
                  "    pm.collectionVariables.set('accessTokenExpiresAt', String(Date.now() + ttl * 1000));",
                  "    pm.collectionVariables.set('accessTokenGrantType', 'password');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "url": "{{baseUrl}}/oauth/token",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password" },
                { "key": "username", "value": "{{devUsername}}" },
                { "key": "password", "value": "{{devPassword}}" },
                { "key": "client_id", "value": "{{citizenClientId}}" },
                { "key": "client_secret", "value": "{{citizenClientSecret}}" }
              ]
            }
          }
        },
        {
          "name": "OAuth Token (password grant — admin)",
          "event": [

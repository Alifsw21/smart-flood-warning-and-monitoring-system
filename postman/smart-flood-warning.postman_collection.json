{
  "info": {
    "name": "Smart Flood Warning API",
    "description": "Postman collection for smart-flood-warning-and-monitoring-system (Spec §12).\n\nUsage:\n1. Set collection variables if needed (defaults target local docker compose).\n2. Run **OAuth Token (password grant)** — accessToken and refreshToken are saved automatically.\n3. For IoT ingest, run **OAuth Token (client_credentials)** first (Node-RED uses the gateway client).\n4. Protected requests use {{accessToken}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3530" },
    { "key": "oauthUrl", "value": "http://localhost:3531" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "citizenClientId", "value": "citizen-app" },
    { "key": "citizenClientSecret", "value": "CitizenSecretDev123" },
    { "key": "gatewayClientId", "value": "gateway" },
    { "key": "gatewayClientSecret", "value": "GatewaySecretDev123" },
    { "key": "devUsername", "value": "hadiputra2" },
    { "key": "devPassword", "value": "kelompok2dev" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "OAuth Token (password grant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.access_token) {",
                  "        pm.collectionVariables.set('accessToken', json.access_token);",
                  "    }",
                  "    if (json.refresh_token) {",
                  "        pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "url": "{{baseUrl}}/oauth/token",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password" },
                { "key": "username", "value": "{{devUsername}}" },
                { "key": "password", "value": "{{devPassword}}" },
                { "key": "client_id", "value": "{{citizenClientId}}" },
                { "key": "client_secret", "value": "{{citizenClientSecret}}" }
              ]
            }
          }
        },
        {
          "name": "OAuth Token (client_credentials)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.access_token) {",
                  "        pm.collectionVariables.set('accessToken', json.access_token);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/oauth/token",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grant_type\": \"client_credentials\",\n  \"client_id\": \"{{gatewayClientId}}\",\n  \"client_secret\": \"{{gatewayClientSecret}}\"\n}"
            }
          }
        },
        {
          "name": "OAuth Token (refresh_token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.access_token) {",
                  "        pm.collectionVariables.set('accessToken', json.access_token);",
                  "    }",
                  "    if (json.refresh_token) {",
                  "        pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/oauth/token",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grant_type\": \"refresh_token\",\n  \"client_id\": \"{{citizenClientId}}\",\n  \"client_secret\": \"{{citizenClientSecret}}\",\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "POST /api/auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    const token = json.access_token || json.token;",
                  "    if (token) {",
                  "        pm.collectionVariables.set('accessToken', token);",
                  "    }",
                  "    if (json.refresh_token) {",
                  "        pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{devUsername}}\",\n  \"password\": \"{{devPassword}}\"\n}"
            }
          }
        },
        {
          "name": "GET /api/auth/profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/auth/profile"
          }
        },
        {
          "name": "POST /oauth/introspect",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/oauth/introspect",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{accessToken}}\",\n  \"client_id\": \"{{gatewayClientId}}\",\n  \"client_secret\": \"{{gatewayClientSecret}}\"\n}"
            }
          }
        },
        {
          "name": "POST /oauth/revoke",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/oauth/revoke",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{accessToken}}\",\n  \"client_id\": \"{{gatewayClientId}}\",\n  \"client_secret\": \"{{gatewayClientSecret}}\"\n}"
            }
          }
        },
        {
          "name": "Gateway Health",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" }
        },
        {
          "name": "GET /metrics",
          "request": { "method": "GET", "url": "{{baseUrl}}/metrics" }
        }
      ]
    },
    {
      "name": "Citizen (php-user)",
      "item": [
        {
          "name": "GET /api/citizens (alias)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/citizens"

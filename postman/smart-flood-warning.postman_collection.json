{
  "info": {
    "name": "Smart Flood Warning API",
    "description": "Postman collection for smart-flood-warning-and-monitoring-system (Spec §12).\n\nUsage:\n1. Set collection variables if needed (defaults target local docker compose).\n2. Protected requests auto-fetch {{accessToken}} via collection pre-request script (password grant, with refresh fallback).\n3. IoT folder auto-fetches client_credentials token (same flow as Node-RED S1).\n4. You can still run Auth requests manually to switch users or debug OAuth.\n5. For admin-only routes (e.g. GET /api/citizens), set devUsername/devPassword to an admin account (dinasari1).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const saveTokenResponse = (json) => {",
          "    if (json.access_token) {",
          "        pm.collectionVariables.set('accessToken', json.access_token);",
          "    }",
          "    if (json.refresh_token) {",
          "        pm.collectionVariables.set('refreshToken', json.refresh_token);",
          "    }",
          "    pm.collectionVariables.set('accessTokenGrantType', 'password');",
          "    const ttl = Number(json.expires_in || 3600);",
          "    pm.collectionVariables.set('accessTokenExpiresAt', String(Date.now() + ttl * 1000));",
          "};",
          "",
          "const shouldSkipAutoAuth = () => {",
          "    const path = pm.request.url.getPath();",
          "    const name = pm.info.requestName || '';",
          "    if (path === '/health' || path === '/metrics') return true;",
          "    if (path === '/oauth/token' || path === '/oauth/introspect' || path === '/oauth/revoke') return true;",
          "    if (path.startsWith('/api/auth/login')) return true;",
          "    if (path.startsWith('/iot/')) return true;",
          "    if (name.startsWith('OAuth Token') || name === 'POST /api/auth/login') return true;",
          "    if (name === 'Gateway Health' || name === 'GET /metrics') return true;",
          "    return false;",
          "};",
          "",
          "const tokenStillValid = () => {",
          "    const token = pm.collectionVariables.get('accessToken');",
          "    const expiresAt = Number(pm.collectionVariables.get('accessTokenExpiresAt') || '0');",
          "    const skewMs = 60 * 1000;",
          "    return Boolean(token) && expiresAt > 0 && Date.now() < expiresAt - skewMs;",
          "};",
          "",
          "const ensurePasswordGrantToken = async () => {",
          "    if (shouldSkipAutoAuth() || tokenStillValid()) {",
          "        return;",
          "    }",
          "",
          "    const baseUrl = pm.collectionVariables.get('baseUrl');",
          "    const refreshToken = pm.collectionVariables.get('refreshToken');",
          "    let response;",
          "",
          "    if (refreshToken) {",
          "        response = await pm.sendRequest({",
          "            url: `${baseUrl}/oauth/token`,",
          "            method: 'POST',",
          "            header: { 'Content-Type': 'application/json' },",
          "            body: {",
          "                mode: 'raw',",
          "                raw: JSON.stringify({",
          "                    grant_type: 'refresh_token',",
          "                    client_id: pm.collectionVariables.get('citizenClientId'),",
          "                    client_secret: pm.collectionVariables.get('citizenClientSecret'),",
          "                    refresh_token: refreshToken,",
          "                }),",
          "            },",
          "        });",
          "    }",
          "",
          "    if (!response || response.code !== 200) {",
          "        response = await pm.sendRequest({",
          "            url: `${baseUrl}/oauth/token`,",
          "            method: 'POST',",
          "            header: { 'Content-Type': 'application/x-www-form-urlencoded' },",
          "            body: {",
          "                mode: 'urlencoded',",
          "                urlencoded: [",
          "                    { key: 'grant_type', value: 'password' },",
          "                    { key: 'username', value: pm.collectionVariables.get('devUsername') },",
          "                    { key: 'password', value: pm.collectionVariables.get('devPassword') },",
          "                    { key: 'client_id', value: pm.collectionVariables.get('citizenClientId') },",
          "                    { key: 'client_secret', value: pm.collectionVariables.get('citizenClientSecret') },",
          "                ],",
          "            },",
          "        });",
          "    }",
          "",
          "    if (response.code !== 200) {",
          "        throw new Error(`Auto OAuth failed (${response.code}): ${response.text()}`);",
          "    }",
          "",
          "    saveTokenResponse(response.json());",
          "};",
          "",
          "await ensurePasswordGrantToken();"
        ]
      }
    }
  ],
